# =============================================================================
# .gitignore para Cliente Integral - Despliegue en AKS
# =============================================================================

# -----------------------------------------------------------------------------
# Variables de entorno y secretos
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
secrets.toml
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Entornos virtuales
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/
.conda/
conda-env/

# ---------------------------

*.pyc

# ---------------------------

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
views/__pycache__
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover

# -----------------------------------------------------------------------------
# Logs y archivos temporales
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Datos locales (no subir datos sensibles)
# -----------------------------------------------------------------------------
data/
*.csv
*.xlsx
*.xls
*.parquet
*.db
*.sqlite

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Docker (archivos locales de desarrollo)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Kubernetes / AKS (archivos locales de configuración)
# -----------------------------------------------------------------------------
kubeconfig
*.kubeconfig
kube/
.kube/
helm-values-local.yaml
*-local.yaml
manifests-out/

# -----------------------------------------------------------------------------
# Certificados SSL (proteger llaves privadas)
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# Azure
# -----------------------------------------------------------------------------
.azure/
azure.json

# -----------------------------------------------------------------------------
# Terraform (si se usa para IaC)
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars

# -----------------------------------------------------------------------------
# Misceláneos
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.cache/
